{
  "name": "@dumas/rapier",
  "version": "0.0.0",
  "description": "Rapier physics integration for Dumas, powered by @tresjs/rapier.",
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack && vue-tsc --project tsconfig.build.json --declaration --emitDeclarationOnly",
    "dev": "vp pack --watch",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@tresjs/rapier": "file:../../../tresjs-rapier"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/three": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "three": "catalog:",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.11",
    "vue-tsc": "catalog:"
  },
  "peerDependencies": {
    "@tresjs/core": "^5.0.0",
    "vue": "^3.5.0"
  }
}
